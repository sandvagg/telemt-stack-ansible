panel_admin_username: "admin"
# Authentication: plain password + auto-hashe

# Plain password (for your convenience)
# If you change this, the hash will be regenerated on next deploy
panel_password: ""

# Bcrypt hash (auto-generated from panel_password if missing)
# If you only have a hash via bcrypt, rounds=10 (no plain), leave panel_password empty
panel_password_hash: ""

bot_token: ""     # Telegram Bot API token from @BotFather; restrict via BotFather settings if possible
bot_admin_ids:    # Your Telegram id. Whitelist: only these Telegram user IDs can execute admin commands
  - 000000000

telemt_api_auth_header: ""  # Custom header for internal API auth (panel→telemt); treat as API key

# === TELEMT USERS ===
telemt_users:
  user1: ""     # Generates automatically if not filled. Per-user API keys for telemt access; format: openssl rand -hex 16 (32 hex chars)
  #user2: ""

# validation flags
_secrets_initialized: false
